# ─────────────────────────────────────────────────────────────────────────────
# Willow UI — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the backend API (no trailing slash).
# Leave empty to use the same origin as the dev server / CDN (proxy setup).
# Example: https://api.willow.coding2themax.com
VITE_API_BASE_URL=

# Admin token used to authenticate against the API.
# This value is also used by LoginGate for local pre-validation when set.
# In production this should be a strong random secret (e.g. openssl rand -hex 32).
VITE_ADMIN_TOKEN=

# Set to "true" to enable the SOLD banner on the hero and disable the inquiry form.
# Toggle this without a code deployment via a GitHub Actions variable (vars.VITE_SOLD).
VITE_SOLD=false
